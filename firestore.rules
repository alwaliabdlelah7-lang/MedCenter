rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasPermission(perm) {
      return isSignedIn() && (getUserData().permissions.hasAny([perm]) || getUserData().permissions.hasAny(['all']));
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['id', 'username', 'name', 'role', 'permissions', 'status']) 
               && data.id is string && data.id.size() <= 64
               && data.username is string && data.username.size() <= 50
               && data.name is string && data.name.size() <= 100
               && data.role in ['admin', 'doctor', 'nurse', 'pharmacist', 'lab_tech', 'receptionist']
               && data.permissions is list
               && data.status in ['active', 'inactive'];
      }

      allow get: if isOwner(userId) || isAdmin() || hasPermission('admin');
      allow list: if isAdmin() || hasPermission('admin');

      allow create: if (isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/users/$(request.auth.uid))))
                      && isValidUser(incoming());

      allow update: if (isAdmin() || hasPermission('admin')) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'permissions', 'role', 'lastLogin'])
      ) || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['lastLogin', 'name']));

      allow delete: if isAdmin() && !isOwner(userId);
    }

    // --- Hospital Data Rules ---
    
    // Patients, Appointments, Doctors, Clinics, Departments
    match /patients/{id} {
      allow read: if hasPermission('clinical') || hasPermission('registration') || hasPermission('billing');
      allow write: if hasPermission('clinical') || hasPermission('registration');
    }
    
    match /appointments/{id} {
      allow read: if hasPermission('clinical') || hasPermission('registration');
      allow write: if hasPermission('clinical') || hasPermission('registration');
    }
    
    match /doctors/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin');
    }
    
    match /nurses/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin');
    }
    
    match /departments/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin');
    }
    
    match /clinics/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin');
    }

    // Pharmacy
    match /pharmacy_items/{id} {
      allow read: if hasPermission('pharmacy') || hasPermission('clinical');
      allow write: if hasPermission('pharmacy');
    }
    
    match /pharmacy_sales/{id} {
      allow read: if hasPermission('pharmacy') || hasPermission('billing');
      allow write: if hasPermission('pharmacy');
    }
    
    match /master_medicines/{id} {
      allow read: if hasPermission('pharmacy') || hasPermission('clinical');
      allow write: if hasPermission('pharmacy') || hasPermission('admin');
    }

    // Lab
    match /lab_tests/{id} {
      allow read: if hasPermission('lab') || hasPermission('clinical');
      allow write: if hasPermission('lab') || hasPermission('clinical');
    }
    
    match /master_lab_tests/{id} {
      allow read: if hasPermission('lab') || hasPermission('clinical');
      allow write: if hasPermission('lab') || hasPermission('admin');
    }

    // Radiology
    match /radiology_scans/{id} {
      allow read: if hasPermission('clinical') || hasPermission('lab');
      allow write: if hasPermission('clinical') || hasPermission('lab');
    }

    // Billing & Services
    match /receipts/{id} {
      allow read: if hasPermission('billing') || hasPermission('admin');
      allow write: if hasPermission('billing');
    }
    
    match /services/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin');
    }

    // Operations & Inpatients
    match /operations/{id} {
      allow read: if hasPermission('clinical');
      allow write: if hasPermission('clinical');
    }

    match /inpatients/{id} {
      allow read: if hasPermission('clinical') || hasPermission('registration');
      allow write: if hasPermission('clinical') || hasPermission('registration');
    }

    // Dynamic Fields (Configuration)
    match /dynamic_fields/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('admin');
    }

    // Records
    match /prescriptions/{id} {
      allow read: if hasPermission('clinical') || hasPermission('pharmacy');
      allow write: if hasPermission('clinical');
    }
    
    match /clinical_visits/{id} {
      allow read: if hasPermission('clinical');
      allow write: if hasPermission('clinical');
    }

    // --- Audit Log Rules ---
    match /audit_logs/{logId} {
      allow read: if isAdmin() || hasPermission('admin');
      allow create: if isSignedIn();
    }

    // --- Global connection test ---
    match /_connection_test_/{docId} {
      allow read: if isSignedIn();
    }
  }
}
