rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isAdmin() { return hasRole('admin'); }
    function isDoctor() { return hasRole('doctor'); }
    function isNurse() { return hasRole('nurse'); }
    function isReceptionist() { return hasRole('receptionist'); }
    function isPharmacist() { return hasRole('pharmacist'); }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // -------------------------------------------------------------------------
    // DENY ALL DEFAULT
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      // Only admins can create/update users. Users can't change their own roles.
      allow create, update: if isAdmin() && isValidUser(incoming());
      
      function isValidUser(data) {
        return data.uid is string && data.uid == userId &&
               data.email is string && data.email.size() <= 100 &&
               data.role in ['admin', 'doctor', 'nurse', 'receptionist', 'pharmacist'];
      }
    }

    // -------------------------------------------------------------------------
    // DOCTORS & NURSES & DEPARTMENTS (Staff and Config)
    // -------------------------------------------------------------------------
    match /doctors/{doctorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /nurses/{nurseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // PATIENTS
    // -------------------------------------------------------------------------
    match /patients/{patientId} {
      allow read: if isSignedIn() && (isAdmin() || isDoctor() || isNurse() || isReceptionist() || isPharmacist());
      allow create: if (isAdmin() || isReceptionist()) && isValidPatient(incoming());
      allow update: if (isAdmin() || isReceptionist() || isDoctor() || isNurse()) && 
                    isValidPatient(incoming()) &&
                    incoming().fileNumber == existing().fileNumber; // Immutable ID

      function isValidPatient(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.fileNumber is string && data.fileNumber.size() > 0;
      }
    }

    // -------------------------------------------------------------------------
    // APPOINTMENTS
    // -------------------------------------------------------------------------
    match /appointments/{appId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isReceptionist()) && isValidAppointment(incoming());
      allow update: if (isAdmin() || isReceptionist() || isDoctor()) && 
                    isValidAppointment(incoming());

      function isValidAppointment(data) {
        return data.patientId is string && data.doctorId is string &&
               data.date is string && data.status in ['scheduled', 'confirmed', 'cancelled', 'completed'];
      }
    }

    // -------------------------------------------------------------------------
    // PHARMACY
    // -------------------------------------------------------------------------
    match /pharmacy_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isPharmacist();
    }

    // -------------------------------------------------------------------------
    // RECEIPTS (FINANCIAL)
    // -------------------------------------------------------------------------
    match /receipts/{receiptId} {
      allow read: if isAdmin() || isReceptionist();
      allow create: if (isAdmin() || isReceptionist()) && isValidReceipt(incoming());
      allow update: if isAdmin(); 

      function isValidReceipt(data) {
        return data.amount is number && data.amount >= 0 &&
               data.doctorId is string && data.serviceId is string;
      }
    }
  }
}
