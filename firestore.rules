rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Bootstrapped Admin logic
    function isBootstrappedAdmin() {
      return isSignedIn() && request.auth.token.email == 'alwaliabdlelah7@gmail.com' && request.auth.token.email_verified == true;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isBootstrappedAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'admin');
    }

    function hasPermission(p) {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).permissions.hasAny([p]));
    }

    function hasAnyPermission(ps) {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).permissions.hasAny(ps));
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'role', 'permissions', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.username is string && data.username.size() <= 64
        && data.role in ['admin', 'doctor', 'nurse', 'receptionist', 'pharmacist', 'lab_tech']
        && data.permissions is list
        && data.status in ['active', 'inactive'];
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['id', 'name', 'fileNumber'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.fileNumber is string && data.fileNumber.size() <= 50;
    }

    // --- Rules for Collections ---
    match /_connection_test_/{id} {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if (isAdmin() || isBootstrappedAdmin()) && isValidUser(incoming());
      allow update: if (isAdmin() || request.auth.uid == userId) && isValidUser(incoming())
                       && incoming().id == existing().id 
                       && (isAdmin() || incoming().role == existing().role);
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (hasAnyPermission(['registration', 'admin']) || isBootstrappedAdmin()) && isValidPatient(incoming());
      allow update: if isSignedIn() && (hasAnyPermission(['clinical', 'registration', 'admin']) || isBootstrappedAdmin()) && isValidPatient(incoming());
      allow delete: if isAdmin();
    }

    match /clinical_visits/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['clinical', 'admin']); }
    match /prescriptions/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['clinical', 'pharmacy', 'admin']); }
    match /lab_tests/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['clinical', 'lab', 'admin']); }
    match /radiology_scans/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['clinical', 'lab', 'admin']); }
    
    match /departments/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /clinics/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /doctors/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /nurses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /services/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /operations/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /master_medicines/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /master_lab_tests/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /pharmacy_items/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['pharmacy', 'admin']); }
    match /appointments/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['registration', 'clinical', 'admin']); }
    match /receipts/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['billing', 'admin']); }
    match /companions/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['registration', 'admin']); }
    match /inpatients/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['registration', 'clinical', 'admin']); }
    match /fhir_patients/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['clinical', 'registration', 'admin']); }
    match /fhir_observations/{id} { allow read: if isSignedIn(); allow write: if hasAnyPermission(['clinical', 'lab', 'admin']); }
    match /dynamic_fields/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}
