rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role-based access could be added here later (e.g. isAdmin())
    
    // Global Collections (Accessible by all staff)
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In production, restrict to Admin
    }
    
    match /doctors/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /nurses/{nurseId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /operations/{opId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /clinics/{clinicId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /companions/{compId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /inpatients/{inpatientId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /receipts/{receiptId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
