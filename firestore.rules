rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getAuthUserData() {
      return getUserData(request.auth.uid);
    }

    function hasRole(role) {
      return isSignedIn() && getAuthUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function hasPermission(p) {
      return isSignedIn() && (getAuthUserData().permissions.hasAny([p]) || isAdmin());
    }

    function hasAnyPermission(ps) {
      return isSignedIn() && (getAuthUserData().permissions.hasAny(ps) || isAdmin());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'role', 'permissions', 'status'])
        && data.id is string
        && data.username is string
        && data.role in ['admin', 'doctor', 'nurse', 'receptionist', 'pharmacist', 'lab_tech']
        && data.permissions is list
        && data.status in ['active', 'inactive'];
    }

    // --- Rules for Collections ---

    // USERS: Only admins or owner (read)
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if (isAdmin() || request.auth.uid == userId) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // PATIENTS: Clinical, Admin, Receptionists (Registration)
    match /patients/{patientId} {
      allow read: if isSignedIn() && hasAnyPermission(['clinical', 'read_only', 'registration']);
      allow create: if isSignedIn() && hasAnyPermission(['registration', 'admin']);
      allow update: if isSignedIn() && hasAnyPermission(['clinical', 'registration', 'admin']);
      allow delete: if isAdmin();
    }

    // CLINICAL DATA: clinical or Admin
    match /clinical_visits/{visitId} {
      allow read: if isSignedIn() && (hasPermission('clinical') || isAdmin());
      allow create: if isSignedIn() && (hasPermission('clinical') || isAdmin());
      allow update: if isSignedIn() && (hasPermission('clinical') || isAdmin());
      allow delete: if isAdmin();
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isSignedIn() && hasAnyPermission(['clinical', 'pharmacy', 'admin']);
      allow create: if isSignedIn() && hasAnyPermission(['clinical', 'admin']);
      allow update: if isSignedIn() && hasAnyPermission(['clinical', 'pharmacy', 'admin']);
      allow delete: if isAdmin();
    }

    match /lab_tests/{testId} {
      allow read: if isSignedIn() && hasAnyPermission(['clinical', 'lab', 'admin']);
      allow create: if isSignedIn() && hasAnyPermission(['clinical', 'admin']);
      allow update: if isSignedIn() && hasAnyPermission(['clinical', 'lab', 'admin']);
      allow delete: if isAdmin();
    }

    // MASTER DATA: Read for all signed in, Write for Admin
    match /departments/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /clinics/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /doctors/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /nurses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /services/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /operations/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // PHARMACY
    match /pharmacy_items/{itemId} {
      allow read: if isSignedIn() && hasAnyPermission(['pharmacy', 'clinical', 'admin']);
      allow write: if hasPermission('pharmacy') || isAdmin();
    }

    // APPOINTMENTS
    match /appointments/{appointmentId} {
      allow read: if isSignedIn();
      allow write: if hasAnyPermission(['registration', 'clinical', 'admin']);
    }

    // RECEIPTS
    match /receipts/{receiptId} {
      allow read: if isSignedIn() && hasAnyPermission(['billing', 'read_only', 'admin']);
      allow write: if hasPermission('billing') || isAdmin();
    }

    // FHIR Patient Resources
    match /fhir_patients/{id} {
      allow read: if isSignedIn() && hasAnyPermission(['clinical', 'read_only', 'registration']);
      allow create, update: if isSignedIn() && hasAnyPermission(['clinical', 'registration', 'admin']);
      allow delete: if isAdmin();
    }

    // FHIR Observation Resources
    match /fhir_observations/{id} {
      allow read: if isSignedIn() && hasAnyPermission(['clinical', 'read_only', 'lab']);
      allow create, update: if isSignedIn() && hasAnyPermission(['clinical', 'lab', 'admin']);
      allow delete: if isAdmin();
    }
  }
}
