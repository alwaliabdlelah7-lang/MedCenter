{
  "name": "med-center-his",
  "private": true,
  "description": "نظام إدارة المنشآت الطبية المتكامل - MedCenter Hospital Information System",
  "version": "1.0.0",
  "author": "Alwali Abdlelah",
  "type": "module",
  "main": "electron-main.cjs",
  "overrides": {
    "uuid": "^14.0.0",
    "@tootallnate/once": "^3.0.1"
  },
  "scripts": {
    "dev": "fuser -k 5000/tcp 2>/dev/null; tsx server.ts",
    "build": "vite build",
    "build:web": "vite build",
    "build:android": "vite build && npx cap sync android && npx cap open android",
    "build:android:apk": "vite build && npx cap sync android",
    "build:windows": "vite build && electron-builder --win --portable",
    "build:linux": "vite build && electron-builder --linux",
    "build:mac": "vite build && electron-builder --mac",
    "build:all": "vite build && npx cap sync android",
    "preview": "vite preview",
    "clean": "rm -rf dist dist_desktop",
    "lint": "tsc --noEmit",
    "start": "tsx server.ts",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5000 && electron .\"",
    "desktop:build:win": "npm run build && electron-builder --win",
    "desktop:build:mac": "npm run build && electron-builder --mac",
    "desktop:build:linux": "npm run build && electron-builder --linux",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npx cap run android"
  },
  "build": {
    "appId": "com.alwali.medcenter",
    "productName": "ايداع الطبي - MedCenter HIS",
    "copyright": "© 2026 Alwali Abdlelah",
    "directories": {
      "output": "dist_desktop",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "public/logo512.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/logo512.png",
      "category": "Office"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo512.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@google/genai": "^1.50.1",
    "@supabase/supabase-js": "^2.105.1",
    "@vitejs/plugin-react": "^5.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "path-to-regexp": "^8.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.5"
  }
}
