{
  "name": "med-center-his",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "server-dist.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --outfile=server-dist.js",
    "start": "NODE_ENV=production node server-dist.js",
    "mobile:sync": "npx cap sync",
    "mobile:build": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "desktop:build:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.12",
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "~6.0.3"
  },
  "build": {
    "appId": "com.alwali.medcenter",
    "productName": "MedCenter HIS",
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  }
}
