{
  "name": "med-center-his",
  "private": true,
  "description": "نظام إدارة المنشآت الطبية المتكامل - MedCenter Hospital Information System",
  "version": "1.0.0",
  "author": "Alwali Abdlelah",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start": "tsx server.ts",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "desktop:build:win": "npm run build && electron-builder --win",
    "desktop:build:mac": "npm run build && electron-builder --mac",
    "desktop:build:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.alwali.medcenter",
    "productName": "MedCenter HIS",
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.16.2",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@google/genai": "^1.50.1",
    "@supabase/supabase-js": "^2.104.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^5.2.0",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-openid-connect": "^2.20.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "path-to-regexp": "^8.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "vite": "^6.4.2",
    "wait-on": "^9.0.5"
  }
}
