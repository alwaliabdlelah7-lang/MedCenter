{
  "name": "med-center-his",
  "private": true,
  "description": "نظام إدارة المنشآت الطبية المتكامل - MedCenter Hospital Information System",
  "version": "1.0.0",
  "author": "Alwali Abdlelah",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "start": "node dist/server.cjs",
    "mobile:sync": "npx cap sync",
    "mobile:build": "npm run build && npx cap sync android && cd android && chmod +x gradlew && ./gradlew assembleDebug",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "desktop:build:win": "npm run build && electron-builder --win",
    "desktop:build:mac": "npm run build && electron-builder --mac",
    "desktop:build:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.alwali.medcenter",
    "productName": "MedCenter HIS",
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@google/genai": "^2.8.0",
    "@supabase/supabase-js": "^2.107.0",
    "@vitejs/plugin-react": "^6.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "path-to-regexp": "^8.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  }
}
