modules = ["nodejs-20"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 24678
externalPort = 80

[deployment]
deploymentTarget = "static"
publicDir = "dist/public"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
