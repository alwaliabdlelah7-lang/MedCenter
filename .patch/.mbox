4. هيكل قاعدة البيانات المتكاملة (PostgreSQL / SQLite)

الجداول الرئيسية (اختصار)

الإعدادات والصلاحيات

· users, roles, permissions, user_roles, role_permissions
· config_categories, config_settings, config_profiles, config_profile_settings
· config_audit_log

المرضى والمواعيد

· patients (id, file_number, full_name, phone, gender, birth_date, registration_date)
· appointments (id, patient_id, doctor_id, service_id, status, start_time, end_time, total_cost, ...)
· queue_entries (رابط مع appointment، priority، estimated_wait_time، status)

الأطباء والخدمات

· doctors (user_id, specialization, working_hours JSON, commission_percent)
· services (name_ar, duration_minutes, base_price, free_follow_up_days)
· doctor_service_prices (ربط سعر مخصص)

السجل الطبي

· medical_records (patient_id, doctor_id, date, chief_complaint, history, vitals, diagnosis, plan)
· prescriptions (record_id, drug_id, dosage, duration)
· lab_orders, radiology_orders

الصيدلية

· drugs (scientific_name, brand_names JSON, category, form, strength, requires_prescription)
· drug_prices (drug_id, purchase_price, selling_price, insurance_price, effective_date)
· inventory (batch_number, expiry_date, quantity)

المختبر

· lab_tests (test_name_ar, category, sample_type, price)
· lab_test_parameters (test_id, parameter_name, unit, display_order)
· lab_test_result_ranges (parameter_id, gender, age_min, age_max, normal_min, normal_max)

المالية

· invoices, payments, chart_of_accounts

جميع الجداول مزودة بـ created_at, updated_at وسجل تدقيق خارجي أو triggers.

