rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getAuthUserData() {
      return getUserData(request.auth.uid);
    }

    function hasRole(role) {
      return isSignedIn() && getAuthUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function hasPermission(p) {
      return isSignedIn() && (getAuthUserData().permissions.hasAny([p]) || isAdmin());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'role', 'permissions', 'status'])
        && data.id is string
        && data.username is string
        && data.role in ['admin', 'doctor', 'nurse', 'receptionist', 'pharmacist', 'lab_tech']
        && data.permissions is list
        && data.status in ['active', 'inactive'];
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['id', 'name'])
        && data.id is string
        && data.name is string
        && data.name.size() <= 200;
    }

    // --- Rules for Collections ---

    // USERS: Only admins or owner (read)
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // PATIENTS: Clinical, Admin, Receptionist
    match /patients/{patientId} {
      allow read: if isSignedIn() && (hasPermission('clinical') || hasPermission('read_only') || isAdmin());
      allow create: if isSignedIn() && (hasPermission('read_only') || isAdmin());
      allow update: if isSignedIn() && (hasPermission('clinical') || hasPermission('read_only') || isAdmin());
      allow delete: if isAdmin();
    }

    // CLINICAL DATA: clinical or Admin
    match /clinical_visits/{visitId} {
      allow read: if isSignedIn() && (hasPermission('clinical') || isAdmin());
      allow create: if isSignedIn() && (hasPermission('clinical') || isAdmin());
      allow update: if isSignedIn() && (hasPermission('clinical') || isAdmin());
      allow delete: if isAdmin();
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isSignedIn() && (hasPermission('clinical') || hasPermission('pharmacy') || isAdmin());
      allow create: if isSignedIn() && (hasPermission('clinical') || isAdmin());
      allow update: if isSignedIn() && (hasPermission('clinical') || hasPermission('pharmacy') || isAdmin());
      allow delete: if isAdmin();
    }

    match /lab_tests/{testId} {
      allow read: if isSignedIn() && (hasPermission('clinical') || hasPermission('lab') || isAdmin());
      allow create: if isSignedIn() && (hasPermission('clinical') || isAdmin());
      allow update: if isSignedIn() && (hasPermission('clinical') || hasPermission('lab') || isAdmin());
      allow delete: if isAdmin();
    }

    // MASTER DATA (Specializations, Departments, etc): Read for all signed in, Write for Admin
    match /departments/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /clinics/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /doctors/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /nurses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /services/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /operations/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // PHARMACY
    match /pharmacy_items/{itemId} {
      allow read: if isSignedIn() && (hasPermission('pharmacy') || hasPermission('clinical') || isAdmin());
      allow write: if hasPermission('pharmacy') || isAdmin();
    }

    // APPOINTMENTS
    match /appointments/{appointmentId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('read_only') || hasPermission('clinical') || isAdmin();
    }

    // RECEIPTS
    match /receipts/{receiptId} {
      allow read: if isSignedIn() && (hasPermission('read_only') || isAdmin());
      allow write: if hasPermission('read_only') || isAdmin();
    }
  }
}
