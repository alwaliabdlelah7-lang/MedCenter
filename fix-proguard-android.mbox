Replace getDefaultProguardFile('proguard-android.txt') with optimize variant
if grep -q "getDefaultProguardFile('proguard-android.txt')" "$APP_BUILD_FILE"; then

sed -i.bak "s/getDefaultProguardFile('proguard-android.txt')/getDefaultProguardFile('proguard-android-optimize.txt')/g" "$APP_BUILD_FILE"
echo "Replacement done."
else

echo "No exact proguard reference found; attempting to replace proguard-android.txt occurrences..."
sed -i.bak "s/proguard-android.txt/proguard-android-optimize.txt/g" "$APP_BUILD_FILE" || true
fi

Create branch, commit and push
git checkout -b "$BRANCH_PROGUARD"
git add "$APP_BUILD_FILE"
git commit -m "$COMMIT_MSG_PROGUARD" || { echo "Nothing to commit for proguard change."; git checkout -; }
echo "Attempting to push branch $BRANCH_PROGUARD..."
git push -u origin "$BRANCH_PROGUARD" || echo "Push failed (you may not have remote write)."
else
echo "Warning: $APP_BUILD_FILE not found. Skipping Android proguard fix."
fi

2) Add tsconfig.json if not exists and install types in the right package.json folder
Find package.json that looks like a React/Frontend package (contains 'react' dep)
echo "Searching for package.json that likely corresponds to the frontend..."
FRONTEND_PKG=""

check root first
if [ -f "package.json" ] && grep -q ""react"" package.json 2>/dev/null; then
FRONTEND_PKG="."
fi

if [ -z "$FRONTEND_PKG" ]; then

search first-level directories
for d in */package.json; do

[ -e "$d" ] || continue
dir=$(dirname "$d")
if grep -q "\"react\"" "$d" 2>/dev/null; then
  FRONTEND_PKG="$dir"
  break
fi
done
fi

fallback: if there is a package.json anywhere, pick root or first found
if [ -z "$FRONTEND_PKG" ]; then
if [ -f "package.json" ]; then

FRONTEND_PKG="."
else

found=$(find . -maxdepth 2 -name package.json | head -n 1 || true)
if [ -n "$found" ]; then
  FRONTEND_PKG="$(dirname "$found")"
fi
fi
fi

if [ -n "$FRONTEND_PKG" ]; then
echo "Using frontend package dir: $FRONTEND_PKG"

create tsconfig.json if not exists
TSCONF_PATH="$FRONTEND_PKG/tsconfig.json"
if [ -f "$TSCONF_PATH" ]; then

echo "tsconfig.json already exists at $TSCONF_PATH. Skipping creation."
else

echo "Creating tsconfig.json at $TSCONF_PATH ..."
cat > "$TSCONF_PATH" <<'EOF'
{
"compilerOptions": {

"target": "ES2019",
"lib": ["DOM", "ES2019"],
"module": "ESNext",
"moduleResolution": "node",
"jsx": "react-jsx",
"esModuleInterop": true,
"allowSyntheticDefaultImports": true,
"skipLibCheck": true,
"strict": false,
"forceConsistentCasingInFileNames": true,
"resolveJsonModule": true,
"isolatedModules": true,
"noEmit": true
},
"include": ["src", "src/**/*"],
"exclude": ["node_modules", "build", "dist"]
}
EOF

echo "tsconfig.json created."
fi

Install dev dependencies (typescript and @types)
echo "Installing dev dependencies: typescript @types/react @types/react-dom in $FRONTEND_PKG ..."
pushd "$FRONTEND_PKG" >/dev/null
if command -v npm >/dev/null 2>&1; then

npm install --save-dev typescript @types/react @types/react-dom
elif command -v yarn >/dev/null 2>&1; then

yarn add -D typescript @types/react @types/react-dom
else

echo "No npm or yarn found in PATH. Please install Node.js/npm or run the install commands manually."
popd >/dev/null
exit 1
fi
popd >/dev/null

Commit & push tsconfig and package-lock/yarn changes
git checkout -b "$BRANCH_TS"
git add "$TSCONF_PATH"

add package lock files if changed
if [ -f "$FRONTEND_PKG/package-lock.json" ]; then

git add "$FRONTEND_PKG/package-lock.json"
fi
if [ -f "$FRONTEND_PKG/yarn.lock" ]; then

git add "$FRONTEND_PKG/yarn.lock"
fi
git commit -m "$COMMIT_MSG_TS" || { echo "Nothing to commit for TS changes."; git checkout -; }
echo "Attempting to push branch $BRANCH_TS..."
git push -u origin "$BRANCH_TS" || echo "Push failed (you may not have remote write)."

else
echo "No package.json found anywhere. Skipping TypeScript types installation. If you have a frontend package.json, re-run script from repo root."
fi

echo "Script finished. Recommended next steps:"
echo "1) Run Android build: cd android && ./gradlew assembleDebug"
echo "2) Run TypeScript check (from frontend package dir): npx tsc --noEmit"
echo "3) Open PRs for branches $BRANCH_PROGUARD and $BRANCH_TS if pushed."
echo "If any step fails, paste the error here and I will assist."

End of script
بعد تشغيل السكربت

إن نجحت عملية git push فستجد فَرعين جديدين في الريموت: fix/android-proguard و fix/ts-react-types — افتح Pull Requests منهما إلى main لدمج التعديلات بعد المراجعة.
إن فشل git push لأنك لا تملك أذونات، سيظل كل شيء مُجرّدًا محلياً ويمكنك رفعه يدوياً أو أطلب منك تعليمات رفع عبر GitHub CLI.
