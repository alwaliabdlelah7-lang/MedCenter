{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data stored in Firestore, linked to Firebase Auth UID.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "doctor", "nurse", "pharmacist", "lab_tech", "receptionist"] },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "name", "role", "permissions", "status"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Medical staff: Doctors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "departmentId": { "type": "string" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Patient appointments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "waiting", "in_consultation", "completed", "cancelled", "return"] }
      }
    },
    "PharmacyItem": {
      "title": "Pharmacy Item",
      "description": "Medicine stock item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "stock": { "type": "number" },
        "price": { "type": "number" }
      }
    },
    "Receipt": {
      "title": "Receipt",
      "description": "Billing receipt.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "returned"] }
      }
    },
    "AuditLog": {
      "title": "System Audit Log",
      "description": "Records of system actions for security and tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles by UID"
    },
    "audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System-wide activity logs"
    },
    "patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient records"
    },
    "doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor profiles"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Medical appointments"
    },
    "pharmacy_items/{itemId}": {
      "schema": "PharmacyItem",
      "description": "Inventory of medicines"
    },
    "receipts/{receiptId}": {
      "schema": "Receipt",
      "description": "Financial receipts"
    },
    "departments/{deptId}": { "schema": "object", "description": "Hospital departments" },
    "clinics/{clinicId}": { "schema": "object", "description": "Medical clinics" },
    "services/{serviceId}": { "schema": "object", "description": "Hospital services" },
    "lab_tests/{testId}": { "schema": "object", "description": "Laboratory tests and results" },
    "prescriptions/{prescId}": { "schema": "object", "description": "Medical prescriptions" },
    "clinical_visits/{visitId}": { "schema": "object", "description": "Clinical visit records" },
    "nurses/{nurseId}": { "schema": "object", "description": "Nurse staff" },
    "master_lab_tests/{itemId}": { "schema": "object", "description": "Master list of lab tests" },
    "master_medicines/{itemId}": { "schema": "object", "description": "Master list of medicines" },
    "pharmacy_sales/{saleId}": { "schema": "object", "description": "Pharmacy sales records" },
    "dynamic_fields/{fieldId}": { "schema": "object", "description": "Custom dynamic form fields" },
    "radiology_scans/{scanId}": { "schema": "object", "description": "Radiology scan records and results" },
    "operations/{opId}": { "schema": "object", "description": "Surgical operation records" },
    "inpatients/{patientId}": { "schema": "object", "description": "Inpatient admission records" }
  }
}
